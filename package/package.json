{
    "name": "mdx-svelte",
    "version": "5.0.0",
    "description": "MDX for Svelte. Svelte in Markdown. A Markdown preprocessor for Svelte. A Preprocessor for Svelte that allows you to write Svelte code inside Markdown files.",
    "license": "MIT",
    "repository": "github:babakfp/mdx-svelte",
    "homepage": "https://mdx-svelte.vercel.app",
    "main": "./dist/index.js",
    "scripts": {
        "dev": "rimraf dist && tsc -w",
        "build": "rimraf dist && tsc",
        "prepublishOnly": "rimraf dist && tsc",
        "format": "prettier -w .",
        "test": "vitest"
    },
    "engines": {
        "node": "^24.16.0"
    },
    "peerDependencies": {
        "@sveltejs/kit": "2",
        "svelte": "5"
    },
    "dependencies": {
        "@shikijs/colorized-brackets": "4.1.0",
        "@shikijs/rehype": "4.1.0",
        "hast-util-from-html": "2.0.3",
        "hast-util-select": "6.0.4",
        "hast-util-to-html": "9.0.5",
        "rehype-autolink-headings": "7.1.0",
        "rehype-external-links": "3.0.0",
        "rehype-slug": "6.0.0",
        "rehype-stringify": "10.0.1",
        "rehype-unwrap-images": "1.0.0",
        "remark-directive": "4.0.0",
        "remark-frontmatter": "5.0.0",
        "remark-frontmatter-yaml": "1.3.0",
        "remark-gfm": "4.0.1",
        "remark-parse": "11.0.0",
        "remark-rehype": "11.1.2",
        "remark-toc": "9.0.0",
        "stringify-entities": "4.0.4",
        "unified": "11.0.5",
        "unist-util-remove-position": "5.0.0",
        "unist-util-visit": "5.1.0",
        "valibot": "1.4.1"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "4.7.1",
        "@sveltejs/kit": "2.61.1",
        "@types/hast": "3.0.4",
        "@types/mdast": "4.0.4",
        "@types/node": "24.12.4",
        "mdast-util-directive": "3.1.0",
        "prettier": "3.8.3",
        "rimraf": "6.1.3",
        "svelte": "5.56.1",
        "typescript": "6.0.3",
        "vfile": "6.0.3",
        "vitest": "4.1.8"
    },
    "files": [
        "./dist/",
        "./src/transformers/unified/plugins/remark-github-alerts/styles/"
    ],
    "exports": {
        ".": "./dist/index.js",
        "./unified": "./dist/transformers/unified/index.js",
        "./unified/remark-github-alerts/*": "./src/transformers/unified/plugins/remark-github-alerts/styles/*"
    },
    "keywords": [
        "svelte",
        "markdown",
        "preprocess",
        "preprocessor",
        "mdx",
        "mdsvex",
        "sveltekit",
        "kit"
    ],
    "type": "module",
    "packageManager": "pnpm@11.8.0"
}
